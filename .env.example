# ==============================================================================
# ENVIRONMENT CONFIGURATION FOR AI JOB AGENT
# Copy this file to .env and fill in the values before executing
# ==============================================================================

# Core Settings
NODE_ENV=development
PORT=3000

# Database & Cache (PostgreSQL & Redis)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_job_agent?schema=public
REDIS_URL=redis://localhost:6379

# Inter-Service API URLs
# Note: In docker-compose, these will point to internal service names
BRAIN_ENGINE_URL=http://localhost:8000
# URL of the automation-engine's multi-tenant API (used by the frontend)
AUTOMATION_ENGINE_API_URL=http://localhost:3001

# Groq API Configuration
GROQ_API_KEY=gsk_your_groq_api_key_goes_here
GROQ_MODEL=llama-3.3-70b-versatile

# SMTP Email Notification Credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_TO_EMAIL=your_email@gmail.com

AUTO_APPLY_ENABLED=false

# LinkedIn Automation Settings
# LOCKED: Auto-submission on LinkedIn is permanently disabled regardless of this flag.
# LinkedIn jobs stop at READY status; the dashboard shows a "Review & Submit Manually" CTA.
LINKEDIN_AUTOMATION_ENABLED=false

# Playwright Browser Automation Options
PLAYWRIGHT_HEADLESS=true

# Candidate Details (Greenhouse & Lever applications)
CANDIDATE_FIRST_NAME=John
CANDIDATE_LAST_NAME=Doe
CANDIDATE_EMAIL=candidate@example.com
CANDIDATE_PHONE=+1-555-0199

# ==============================================================================
# Phase 1: Multi-Tenant Foundation — NEW VARIABLES BELOW
# ==============================================================================

# ── S3 / MinIO Resume Storage ─────────────────────────────────────────────────
# For development: uses local MinIO (started by docker-compose).
# For production: replace S3_ENDPOINT with nothing (leave unset) and use real AWS credentials.
S3_BUCKET_NAME=ai-job-agent
S3_REGION=us-east-1
# Set this to the MinIO endpoint for local dev. Remove entirely for real AWS S3.
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── MinIO Admin Credentials (dev only) ────────────────────────────────────────
# These must match AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above for local dev.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Application Plan Limits ───────────────────────────────────────────────────
# FREE plan limit is hardcoded at 4 (see src/config/plans.ts — do not change here).
# PREMIUM limit is configurable via this variable.
PREMIUM_DAILY_LIMIT=50

# ── NextAuth (Dashboard Authentication) ───────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret-at-least-32-chars-long
# The public URL where the frontend is accessible
NEXTAUTH_URL=http://localhost:3002

# ── Phase 1 Pipeline — Default User ──────────────────────────────────────────
# The shared scrape pipeline needs a userId to write Application rows.
# After running `npm run db:seed`, copy the printed demo user ID here.
# In Phase 2 this will be replaced by per-user search profiles.
DEFAULT_USER_ID=
