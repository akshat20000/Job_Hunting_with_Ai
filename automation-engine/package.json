{
  "name": "automation-engine",
  "version": "1.0.0",
  "description": "Scrapes job boards, orchestrates application flows, and automates submissions via Playwright",
  "main": "dist/index.js",
  "type": "module",
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:seed": "tsx db/seed.ts",
    "approve": "tsx src/approve.ts",
    "trigger": "tsx src/trigger.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@prisma/client": "^5.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.2.0",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ioredis": "^5.3.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.11",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.42.1",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^6.4.14",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
