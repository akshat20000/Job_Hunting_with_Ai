{
  "name": "automation-engine",
  "version": "1.0.0",
  "description": "Scrapes job boards, orchestrates application flows, and automates submissions via Playwright",
  "main": "dist/index.js",
  "type": "module",
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx db/seed.ts",
    "approve": "tsx src/approve.ts",
    "trigger": "tsx src/trigger.ts",
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bullmq": "^5.1.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.11",
    "playwright": "^1.42.1",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^6.4.14",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
