datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Auth models (NextAuth)

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  passwordHash  String?
  plan          String          @default("FREE") // FREE | PREMIUM
  emailVerified DateTime?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]
  searchProfile SearchProfile?
  applications  Application[]
  searchRuns    SearchRun[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User-scoped domain models

model SearchProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titles     String[] @default([])
  locations  String[] @default([])
  boards     String[] @default([]) // linkedin | greenhouse | lever
  remoteOnly Boolean  @default(false)
  minSalary  Int?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filePath    String   // S3 object key
  parsedText  String   // extracted plain text for AI use
  content     String   // raw content plain text (used by workers)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Global job data (shared pipeline)

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Job {
  id             String        @id @default(uuid())
  title          String
  description    String
  url            String        @unique
  location       String?
  salary         String?
  status         String        @default("FOUND") // FOUND, MATCHED, TAILORED, READY, APPLYING, APPLIED, RETRYING, FAILED
  score          Float?
  fitExplanation String?
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  applications   Application[]
}

// One row per "Start Job Search" click — the unit the daily quota is
// actually measured against (searching, not applying, consumes a token).
model SearchRun {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boards    String[] @default([])
  titles    String[] @default([])
  createdAt DateTime @default(now())
}

// Per-user Application records

model Application {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          String    @default("FOUND")
  appliedAt       DateTime?
  resumePath      String?   // local PDF path for apply automation
  coverLetterPath String?
  screenshotPath  String?
  errorDetails    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, jobId])
}