datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Job {
  id             String        @id @default(uuid())
  title          String
  description    String
  url            String        @unique
  location       String?
  salary         String?
  status         String        @default("FOUND") // FOUND, MATCHED, TAILORED, READY, APPLYING, SUBMITTED, FAILED
  score          Float?
  fitExplanation String?
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  applications   Application[]
}

model Application {
  id              String    @id @default(uuid())
  jobId           String    @unique
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          String    @default("FOUND")
  appliedAt       DateTime?
  resumePath      String?
  coverLetterPath String?
  screenshotPath  String?
  errorDetails    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Resume {
  id        String   @id @default(uuid())
  name      String
  content   String
  isMaster  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
